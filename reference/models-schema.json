{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ModelsConfig",
  "type": "object",
  "required": ["providers"],
  "properties": {
    "providers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/ProviderConfig" }
    }
  },
  "definitions": {
    "ProviderConfig": {
      "type": "object",
      "properties": {
        "baseUrl": { "type": "string", "minLength": 1 },
        "apiKey": { "type": "string", "minLength": 1, "description": "Supports !command or ENV_VAR" },
        "api": { "type": "string", "minLength": 1 },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "compat": { "$ref": "#/definitions/OpenAICompat" },
        "authHeader": { "type": "boolean" },
        "models": {
          "type": "array",
          "items": { "$ref": "#/definitions/ModelDefinition" }
        },
        "modelOverrides": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/ModelOverride" }
        }
      }
    },
    "ModelDefinition": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "api": { "type": "string", "minLength": 1 },
        "baseUrl": { "type": "string", "minLength": 1 },
        "reasoning": { "type": "boolean" },
        "input": {
          "type": "array",
          "items": { "enum": ["text", "image"] }
        },
        "cost": {
          "type": "object",
          "required": ["input", "output", "cacheRead", "cacheWrite"],
          "properties": {
            "input": { "type": "number" },
            "output": { "type": "number" },
            "cacheRead": { "type": "number" },
            "cacheWrite": { "type": "number" }
          }
        },
        "contextWindow": { "type": "number" },
        "maxTokens": { "type": "number" },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "compat": { "$ref": "#/definitions/OpenAICompat" }
      }
    },
    "ModelOverride": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "reasoning": { "type": "boolean" },
        "input": {
          "type": "array",
          "items": { "enum": ["text", "image"] }
        },
        "cost": {
          "type": "object",
          "properties": {
            "input": { "type": "number" },
            "output": { "type": "number" },
            "cacheRead": { "type": "number" },
            "cacheWrite": { "type": "number" }
          }
        },
        "contextWindow": { "type": "number" },
        "maxTokens": { "type": "number" },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "compat": { "$ref": "#/definitions/OpenAICompat" }
      }
    },
    "OpenAICompat": {
      "oneOf": [
        { "$ref": "#/definitions/OpenAICompletionsCompat" },
        { "$ref": "#/definitions/OpenAIResponsesCompat" }
      ]
    },
    "OpenAICompletionsCompat": {
      "type": "object",
      "properties": {
        "supportsStore": { "type": "boolean" },
        "supportsDeveloperRole": { "type": "boolean" },
        "supportsReasoningEffort": { "type": "boolean" },
        "reasoningEffortMap": {
          "type": "object",
          "properties": {
            "minimal": { "type": "string" },
            "low": { "type": "string" },
            "medium": { "type": "string" },
            "high": { "type": "string" },
            "xhigh": { "type": "string" }
          }
        },
        "supportsUsageInStreaming": { "type": "boolean" },
        "maxTokensField": { "enum": ["max_completion_tokens", "max_tokens"] },
        "requiresToolResultName": { "type": "boolean" },
        "requiresAssistantAfterToolResult": { "type": "boolean" },
        "requiresThinkingAsText": { "type": "boolean" },
        "thinkingFormat": { "enum": ["openai", "openrouter", "zai", "qwen", "qwen-chat-template"] },
        "openRouterRouting": { "$ref": "#/definitions/OpenRouterRouting" },
        "vercelGatewayRouting": { "$ref": "#/definitions/VercelGatewayRouting" },
        "supportsStrictMode": { "type": "boolean" }
      }
    },
    "OpenAIResponsesCompat": {
      "type": "object",
      "properties": {}
    },
    "OpenRouterRouting": {
      "type": "object",
      "properties": {
        "allow_fallbacks": { "type": "boolean" },
        "require_parameters": { "type": "boolean" },
        "data_collection": { "enum": ["deny", "allow"] },
        "zdr": { "type": "boolean" },
        "enforce_distillable_text": { "type": "boolean" },
        "order": { "type": "array", "items": { "type": "string" } },
        "only": { "type": "array", "items": { "type": "string" } },
        "ignore": { "type": "array", "items": { "type": "string" } },
        "quantizations": { "type": "array", "items": { "type": "string" } },
        "sort": {
          "anyOf": [
            { "type": "string" },
            {
              "type": "object",
              "properties": {
                "by": { "type": "string" },
                "partition": { "type": ["string", "null"] }
              }
            }
          ]
        },
        "max_price": {
          "type": "object",
          "properties": {
            "prompt": { "type": ["number", "string"] },
            "completion": { "type": ["number", "string"] },
            "image": { "type": ["number", "string"] },
            "audio": { "type": ["number", "string"] },
            "request": { "type": ["number", "string"] }
          }
        },
        "preferred_min_throughput": {
          "anyOf": [{ "type": "number" }, { "$ref": "#/definitions/PercentileCutoffs" }]
        },
        "preferred_max_latency": {
          "anyOf": [{ "type": "number" }, { "$ref": "#/definitions/PercentileCutoffs" }]
        }
      }
    },
    "VercelGatewayRouting": {
      "type": "object",
      "properties": {
        "only": { "type": "array", "items": { "type": "string" } },
        "order": { "type": "array", "items": { "type": "string" } }
      }
    },
    "PercentileCutoffs": {
      "type": "object",
      "properties": {
        "p50": { "type": "number" },
        "p75": { "type": "number" },
        "p90": { "type": "number" },
        "p99": { "type": "number" }
      }
    }
  }
}
